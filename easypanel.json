{
  "name": "pulsosocialv2",
  "version": "1.0.0",
  "type": "static",
  "build": {
    "command": "npm install && npm run easypanel:build",
    "output": "dist"
  },
  "env": {
    "NODE_ENV": "production"
  },
  "routes": [
    {
      "src": "/rest/(.*)",
      "dest": "https://pulsosocialv2-pulsosocialbdv3.dsb9vm.easypanel.host/rest/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, PATCH, OPTIONS",
        "Access-Control-Allow-Headers": "apikey, Authorization, Content-Type, X-Client-Info"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "domains": [
    "pulsossociales.com"
  ]
}
